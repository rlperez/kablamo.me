<custom-card>
  <h2 slot="headline">
    <a href="{{ item.url | url }}">{{ item.data.title }}</a>
  </h2>
  <span slot="date" webc:nokeep>{% include "partials/date.njk" %}</slot>

  <div slot="content">{{ item.data.description | markdownFormat | safe }}</div>
  {% if item.data.tags.length >= 1 %}
    <div slot="tag">
      {% for tag in item.data.tags %}
        {% if tag != "posts" %}
          <span class="button post-tag">{{ tag }}</span>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</custom-card>
